# Database Configuration
# Use DATABASE_URL in production if your host provides one.
# For local Docker Compose runs, DB_HOST should point at the postgres service.
DATABASE_URL=
DB_HOST=localhost
DB_PORT=5432
DB_USER=terrango
DB_PASSWORD=terrango
DB_NAME=terrango
DB_SSL=false

# Redis Configuration
REDIS_URL=redis://localhost:6379

# JWT Secret (change in production!)
JWT_SECRET=terrango-dev-secret

# Environment
NODE_ENV=development

